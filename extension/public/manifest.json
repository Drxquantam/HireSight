{
  "manifest_version": 3,
  "name": "HireSight",
  "description": "AI-powered resume match analysis for job postings.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "HireSight"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.naukri.com/*",
    "https://*.wellfound.com/*",
    "https://*.angel.co/*",
    "https://*/*",
    "http://localhost/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_page": "options.html"
}
